{
  "name": "auto-comment",
  "displayName": "Auto Comment Code Generator",
  "description": "Automatically generates explanatory comments for your code using a local AI model.",
  "version": "0.0.1",
  "publisher": "auto-comment-code-generator",
  "license": "MIT",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "auto-comment.generate",
        "title": "Auto-Comment Code"
      }
    ],
    "configuration": {
      "title": "Auto Comment Code Generator",
      "properties": {
        "autoComment.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Python executable used to run the bundled local comment model."
        },
        "autoComment.inferenceTimeoutMs": {
          "type": "number",
          "default": 45000,
          "minimum": 5000,
          "description": "Maximum time in milliseconds to wait for local model inference before failing."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "^20.2.5",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "eslint": "^8.41.0",
    "glob": "^8.1.0",
    "ts-loader": "^9.4.3",
    "typescript": "^5.1.3",
    "webpack": "^5.85.0",
    "webpack-cli": "^5.1.1"
  }
}
